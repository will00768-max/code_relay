# ============================================================
# Codex Relay 环境变量配置示例
# 使用方法：复制本文件为 .env，然后填入实际值
#   cp .env.example .env
# ============================================================

# [必填] DeepSeek API 密钥
# 从 https://platform.deepseek.com 获取
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# [可选] DeepSeek API 基础地址，默认使用官方地址
# 如需使用代理或私有部署，修改此项
DEEPSEEK_BASE_URL=https://api.deepseek.com

# [可选] 默认使用的 DeepSeek 模型
# 可选值：deepseek-v4-flash（默认，快速低成本）、deepseek-v4-pro（高能力）
DEEPSEEK_MODEL=deepseek-v4-flash

# [可选] 代理服务自身的鉴权 Key
# 设置后，所有请求需在 Authorization 头中携带此 Key 才能访问
# 留空则不启用鉴权（任何人均可调用本服务，生产环境建议设置）
PROXY_API_KEY=

# [可选] 服务监听端口，默认 8000
PORT=8000
